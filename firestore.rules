rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers ----
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ---- users ----
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // ---- directMessages ----
    // chatId = [senderId, receiverId].sort().join('_')
    // Firebase UIDs are 28 alphanumeric chars (no underscores), so '_' is a safe delimiter.
    // chatId correctness is enforced on the client; rules verify the caller is the sender.
    match /directMessages/{messageId} {
      allow read: if isSignedIn()
        && request.auth.uid in [resource.data.senderId, resource.data.receiverId];
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.senderId;
      allow update, delete: if false;
    }

    // ---- threads ----
    match /threads/{threadId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.authorId;
      allow update: if isOwner(resource.data.authorId);
      allow delete: if isOwner(resource.data.authorId);

      // ---- thread comments (subcollection) ----
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.auth.uid == request.resource.data.authorId;
        allow update: if isOwner(resource.data.authorId);
        allow delete: if isOwner(resource.data.authorId);
      }
    }

    // ---- legacy messages (read-only after migration) ----
    match /messages/{messageId} {
      allow read: if isSignedIn()
        && request.auth.uid in [resource.data.senderId, resource.data.receiverId];
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.senderId;
      allow update, delete: if false;
    }
  }
}
